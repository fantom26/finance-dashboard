{
  "name": "finance-visualization",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "json-server db.json --port 3000",
    "build": "vite build",
    "typecheck": "vue-tsc -b",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@amcharts/amcharts5": "^5.11.0",
    "@amcharts/amcharts5-geodata": "^5.1.4",
    "ag-grid-community": "^35.2.1",
    "ag-grid-vue3": "^35.2.1",
    "axios": "^1.16.0",
    "json-server": "^1.0.0-beta.15",
    "maska": "^3.1.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.15.21",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "10.3.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "10.9.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.32.1",
    "vite": "^8.0.0",
    "vue-eslint-parser": "^10.3.0",
    "vue-tsc": "^2.2.10"
  },
  "lint-staged": {
    "src/**/*.{js,ts,vue,html,css}": "prettier --write",
    "src/**/*.{js,ts,vue}": "eslint --fix",
    "src/**/*.{ts,vue}": "yarn typecheck"
  }
}
